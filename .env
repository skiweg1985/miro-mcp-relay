PORT=8787
# IMPORTANT: BASE_URL must be host+port only (no /miro suffix)
# Good:  https://your-domain.example
# Good:  https://your-domain.example:8443
# Bad:   https://your-domain.example/miro
BASE_URL=http://localhost:8787

# Per-profile MCP access token check (X-Relay-Key)
MIRO_RELAY_API_KEY=change-me-long-random-string

# Admin key for profile provisioning/listing (X-Admin-Key)
# If omitted, falls back to MIRO_RELAY_API_KEY
MIRO_RELAY_ADMIN_KEY=change-me-admin-key

# Admin password for web login session (/miro/admin/login)
MIRO_ADMIN_PASSWORD=change-me-admin-password

# Browser flow /miro/start can be open by default.
# Set true to require admin key for /miro/start.
MIRO_START_REQUIRE_ADMIN=false

# Auto-delete pending (not completed) profiles after N minutes.
MIRO_PENDING_PROFILE_TTL_MINUTES=15

# Keep /miro/start preview session for N minutes to avoid duplicate profile creation on refresh.
MIRO_START_PREVIEW_TTL_MINUTES=30

# OAuth email check mode:
# - warn   => fail-open, always connect, but store/show expected vs detected OAuth email
# - strict => block OAuth completion unless expected profile email matches detected OAuth email
MIRO_OAUTH_EMAIL_MODE=warn

# MCP upstream resilience
MIRO_MCP_RETRY_COUNT=2
MIRO_BREAKER_FAIL_THRESHOLD=5
MIRO_BREAKER_OPEN_MS=30000

DATA_DIR=/app/data

MIRO_OAUTH_SCOPE=boards:read boards:write
