PORT=8787
# IMPORTANT: BASE_URL must be host+port only (no /miro suffix)
# Good:  https://your-domain.example
# Good:  https://your-domain.example:8443
# Bad:   https://your-domain.example/miro
BASE_URL=https://your-domain.example

# Per-profile MCP access token check (X-Relay-Key)
MIRO_RELAY_API_KEY=change-me-long-random-string

# Admin key for profile provisioning/listing (X-Admin-Key)
# If omitted, falls back to MIRO_RELAY_API_KEY
MIRO_RELAY_ADMIN_KEY=change-me-admin-key

DATA_DIR=/app/data
