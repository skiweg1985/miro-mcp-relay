# Public app URLs exposed by the proxy / LB
BROKER_PUBLIC_BASE_URL=http://localhost
FRONTEND_BASE_URL=http://localhost
CORS_ORIGINS=http://localhost

# New broker backend
DATABASE_URL=sqlite:///./broker.db

# Session / crypto
SESSION_SECRET=change-me-broker-session-secret
SESSION_COOKIE_NAME=broker_session
SESSION_TTL_HOURS=8
SESSION_SECURE_COOKIE=false
# Optional: if empty, derived from SESSION_SECRET
BROKER_ENCRYPTION_KEY=

# Bootstrap admin user
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
BOOTSTRAP_ADMIN_DISPLAY_NAME=Broker Admin

# Microsoft broker login for end users
MICROSOFT_BROKER_TENANT_ID=common
MICROSOFT_BROKER_CLIENT_ID=
MICROSOFT_BROKER_CLIENT_SECRET=
MICROSOFT_BROKER_SCOPE=openid profile email User.Read

# Miro downstream connection behavior
# OAuth client for Miro Connect (UserConnection); optional if set in Integration config
MIRO_OAUTH_CLIENT_ID=
MIRO_OAUTH_CLIENT_SECRET=
MIRO_OAUTH_SCOPE=boards:read boards:write
MIRO_OAUTH_EMAIL_MODE=warn
MIRO_RETRY_COUNT=2
MIRO_BREAKER_FAIL_THRESHOLD=5
MIRO_BREAKER_OPEN_MS=30000

# Optional: path to legacy Miro relay data for migration/import endpoints
LEGACY_MIRO_DATA_DIR=data
