# Copy to .env.test and adjust. Used with local broker + docker-compose.test.yml (Keycloak).

# Broker (uvicorn from host, SQLite default ok)
DATABASE_URL=sqlite:///./broker-test.db
SESSION_SECRET=test-session-secret-at-least-32-chars-long
BROKER_ENCRYPTION_KEY=
BROKER_PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Keycloak (after: docker compose -f docker-compose.test.yml up -d)
# Issuer: http://localhost:8180/realms/broker-test
# Broker-login client: broker-login (public), secret empty
# Test user: testuser / testpass-change-me

# Sign-in provider (Admin → Sign-in providers), Keycloak realm broker-test:
# provider_key: keycloak
# client_id: broker-login-confidential
# client_secret: broker-test-client-secret-change-me
# issuer: http://localhost:8180/realms/broker-test
# authorization_endpoint: http://localhost:8180/realms/broker-test/protocol/openid-connect/auth
# token_endpoint: http://localhost:8180/realms/broker-test/protocol/openid-connect/token
# userinfo_endpoint: http://localhost:8180/realms/broker-test/protocol/openid-connect/userinfo
# scopes: openid profile email
